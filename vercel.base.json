{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "npm run build:all",
  "functions": {
    "api/index.js": {
      "includeFiles": "{public/**,server-seo.js,server-http-config.js,server-vercel-url.js}",
      "maxDuration": 60
    }
  },
  "redirects": [],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/uploads/:path*", "destination": "/api" },
    { "source": "/robots.txt", "destination": "/api" },
    { "source": "/sitemap.xml", "destination": "/api" },
    { "source": "/bonus/:slug", "destination": "/api" },
    { "source": "/slot/:slug", "destination": "/api" },
    { "source": "/provider/:slug", "destination": "/api" },
    { "source": "/guide/:slug", "destination": "/api" },
    { "source": "/news/:slug", "destination": "/api" },
    { "source": "/bonus.html", "destination": "/api" },
    { "source": "/provider.html", "destination": "/api" },
    { "source": "/slot.html", "destination": "/api" },
    { "source": "/post.html", "destination": "/api" },
    { "source": "/bonus", "destination": "/bonus-hub.html" },
    { "source": "/ewallet", "destination": "/malaysia-ewallet.html" },
    { "source": "/blackjack", "destination": "/games-blackjack.html" },
    { "source": "/roulette", "destination": "/games-roulette.html" },
    { "source": "/baccarat", "destination": "/games-baccarat.html" },
    { "source": "/mobile", "destination": "/mobile.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/components/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
