{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "{public/**,server-seo.js}",
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.888reviews.com" }],
      "destination": "https://888reviews.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|components/).*)",
      "destination": "/api"
    }
  ]
}
